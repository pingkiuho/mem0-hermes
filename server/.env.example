# Choose one model profile below:
# - Local Ollama: private/local, no API key, requires Ollama on the host.
# - OpenAI-compatible: OpenAI, OpenRouter, Xiaomi MiMo, vLLM, etc. using the OpenAI API shape.

# ── Profile A: Local Ollama ───────────────────────────────
MEM0_DEFAULT_LLM_PROVIDER=ollama
MEM0_DEFAULT_LLM_MODEL=qwen3.5:9b-mlx
MEM0_DEFAULT_EMBEDDER_PROVIDER=ollama
MEM0_DEFAULT_EMBEDDER_MODEL=nomic-embed-text
# Must match the embedder output dimension. nomic-embed-text returns 768.
MEM0_EMBEDDING_DIMS=768
# On macOS Docker, use host.docker.internal to reach the host machine.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Profile B: OpenAI-compatible endpoint ─────────────────
# Uncomment this block for OpenAI-compatible providers such as OpenAI,
# OpenRouter, Xiaomi MiMo, vLLM, LiteLLM, or a private gateway.
# MEM0_DEFAULT_LLM_PROVIDER=openai
# MEM0_DEFAULT_LLM_MODEL=gpt-4.1-nano-2025-04-14
# MEM0_DEFAULT_EMBEDDER_PROVIDER=openai
# MEM0_DEFAULT_EMBEDDER_MODEL=text-embedding-3-small
# MEM0_EMBEDDING_DIMS=1536
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: other bundled LLM/embedder providers.
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Postgres — POSTGRES_PASSWORD is required; docker-compose will not start without it.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=9432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_COLLECTION_NAME=mem0

ADMIN_API_KEY=
JWT_SECRET=
# Local development only. Leave false in production.
AUTH_DISABLED=false

# ── Public endpoints and exposed ports ───────────────────
MEM0_API_PORT=9000
MEM0_DASHBOARD_PORT=9001
DASHBOARD_URL=http://localhost:9001
PUBLIC_API_URL=http://localhost:9000
CORS_ORIGINS=http://localhost:9001
APP_DB_NAME=mem0_app

# Providers must be in BUNDLED_*_PROVIDERS (see server/main.py). If you change
# embedder model/provider, also change MEM0_EMBEDDING_DIMS before creating data.

# Anonymous telemetry. Sends a single onboarding event per install
# (install UUID, email domain, server version, source). No PII.
# Set to false to opt out.
MEM0_TELEMETRY=false

# Days of request_logs history to keep when `make prune-logs` runs.
# Wire the prune command into cron/systemd in production.
REQUEST_LOG_RETENTION_DAYS=30
